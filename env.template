## Database notes:
## - The project expects a Postgres database (default `recruitment_ai`).
## - You must enable the `vector` extension in Postgres (the `migrations.init_db()` helper will attempt to create it).
## - Ensure the DB user has privileges to create extensions and tables when running initialization.

# JD upload parsing (openai recommended)
JD_AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini

# Gemini (resume parsing and other features)
GEMINI_API_KEY=your_gemini_api_key_here
CHAT_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="recruitment_ai"
DB_USER="postgres"
DB_PASSWORD="postgres"

# Recruiting mailbox (interviewer, HR, calendar, SMTP)
FROM_EMAIL="recruit@tekleaders.io"
RECRUIT_EMAIL="recruit@tekleaders.io"
INTERVIEWER_EMAIL="recruit@tekleaders.io"
HR_INTERVIEWER_EMAIL="recruit@tekleaders.io"
CALENDAR_EMAIL="recruit@tekleaders.io"
GOOGLE_CALENDAR_CREDENTIALS_PATH="credentials.json"

# Google Meet requires OAuth as recruit@ (run: python setup_calendar_oauth.py)
CALENDAR_AUTH_MODE="oauth"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REFRESH_TOKEN=""

EMAIL_CC_LIST="raghavendra.v@tekleaders.com,sajida.baig@tekleaders.com,janaki.vijinigiri@tekleaders.com"
ADMIN_SECRET="change-this-to-a-long-random-string"

